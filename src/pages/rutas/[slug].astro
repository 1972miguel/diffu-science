---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const rutas = await getCollection('rutas');
  return rutas.map(r => ({
    params: { slug: r.slug }
  }));
}

const { slug } = Astro.params;
const ruta = await getEntry('rutas', slug!);

if (!ruta) return Astro.redirect('/404');

const { Content } = await ruta.render();
---

<BaseLayout title={ruta.data.title}>
  <article class="py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-6">
      {ruta.data.cover && (
        <Image 
          src={ruta.data.cover} 
          alt={ruta.data.title}
          width={1400}
          class="w-full h-96 object-cover rounded-3xl mb-12 shadow-2xl"
        />
      )}
      
      <h1 class="text-5xl md:text-6xl font-bold mb-6">{ruta.data.title}</h1>
      
      <div class="flex flex-wrap gap-6 text-lg text-gray-600 mb-12">
        <div><strong>Dificultad:</strong> {ruta.data.dificultad}</div>
        <div><strong>Distancia:</strong> {ruta.data.distancia_km} km</div>
        <div><strong>Tiempo estimado:</strong> {ruta.data.tiempo_horas} horas</div>
      </div>
      
      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>