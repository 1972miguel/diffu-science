---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog Científico">
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-5xl md:text-6xl font-bold text-center mb-16">Blog</h1>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="group block bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition">
            {post.data.cover && (
              <img src={post.data.cover} alt={post.data.title} class="w-full h-56 object-cover group-hover:scale-105 transition duration-500" />
            )}
            <div class="p-8">
              <time class="text-sm text-gray-500">{post.data.date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <h3 class="text-2xl font-bold mt-2 mb-3 group-hover:text-[var(--color-primary)] transition">{post.data.title}</h3>
              <p class="text-gray-600 line-clamp-3">{post.data.excerpt}</p>
              <p class="mt-6 text-[var(--color-primary)] font-semibold inline-flex items-center">
                Leer más →
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>